generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
}

model CalendarEvent {
  id          String        @id @default(uuid())
  calendarId  String
  title       String
  description String?
  status      EventStatus   @default(PENDING)
  priority    EventPriority @default(MEDIUM)
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean       @default(false)
  color       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("calendar_events")
}
